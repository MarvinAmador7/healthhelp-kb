# Sanity CMS — https://sanity.io
NEXT_PUBLIC_SANITY_PROJECT_ID=your-project-id
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_WRITE_TOKEN=your-write-token      # Editor role, used only in API routes (server-side)
SANITY_WEBHOOK_SECRET=your-webhook-secret

# Algolia Search — https://algolia.com
NEXT_PUBLIC_ALGOLIA_APP_ID=your-app-id
NEXT_PUBLIC_ALGOLIA_SEARCH_API_KEY=your-search-only-key   # Public — safe to expose
ALGOLIA_ADMIN_KEY=your-admin-key         # Secret — indexing scripts only

# GA4
NEXT_PUBLIC_GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# Public site URL (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://project-sxpkl.vercel.app

# Service status page (optional). When set, surfaces a "Service status" link
# in the footer and on the search zero-results screen.
NEXT_PUBLIC_STATUS_URL=

# AI Chatbot (GLO-13) ---------------------------------------------------------

# Vercel AI Gateway. Auto-injected via Vercel OIDC binding when deployed; set
# explicitly for local dev. https://vercel.com/dashboard/ai-gateway
AI_GATEWAY_API_KEY=

# Vercel Postgres (auto-injected on Vercel deploys via the Storage integration).
# Hosts the pgvector store + chat session usage table.
# Apply db/migrations/*.sql before first run via `bun scripts/migrate.ts`.
DATABASE_URL=postgres://user:pass@host/dbname?sslmode=require

# HMAC secret used to sign anonymous chat session cookies. Generate with:
#   openssl rand -hex 32
CHAT_SESSION_SECRET=

# Per-session rate limits (override defaults if needed).
CHAT_RATE_LIMIT_1H=20
CHAT_RATE_LIMIT_24H=200
