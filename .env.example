# Sanity CMS — https://sanity.io
NEXT_PUBLIC_SANITY_PROJECT_ID=your-project-id
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_WRITE_TOKEN=your-write-token      # Editor role, used only in API routes (server-side)
SANITY_WEBHOOK_SECRET=your-webhook-secret

# Algolia Search — https://algolia.com
NEXT_PUBLIC_ALGOLIA_APP_ID=your-app-id
NEXT_PUBLIC_ALGOLIA_SEARCH_API_KEY=your-search-only-key   # Public — safe to expose
ALGOLIA_ADMIN_KEY=your-admin-key         # Secret — indexing scripts only

# GA4
NEXT_PUBLIC_GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# Public site URL (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://help.healthco.com
